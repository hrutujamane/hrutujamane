PORT=5000
MONGODB_URI=mongodb://localhost:27017/internshield
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NODE_ENV=development

# Admin account (created automatically on first server start if no admin exists)
ADMIN_EMAIL=admin@inplasheild.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Rutuja

# Twilio SMS Verification Configuration (optional for fallback to 1234)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
